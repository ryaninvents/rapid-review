#!/usr/bin/env bash
# Initialize a review store for the current project.
#
# Usage:
#   review-start <slug> [<base-ref>]            # remote mode (review a PR branch)
#   review-start --local <slug> [<base-ref>]    # local mode (review against a frozen
#                                                 snapshot of the working tree)
#
# Remote mode: HEAD = merge-base(HEAD, main), work-tree = project directory.
# Local mode:  HEAD = baseline ref's tree (default HEAD), work-tree = a snapshot
#              checkout in $store/snapshot/. The AI keeps editing the project;
#              `review-refresh` advances the snapshot.

set -euo pipefail
_RV_SELF="${BASH_SOURCE[0]}"; while [ -L "$_RV_SELF" ]; do _RV_SELF="$(readlink "$_RV_SELF")"; done; source "$(cd "$(dirname "$_RV_SELF")" && pwd)/review-lib.sh"

mode="remote"
positional=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --local) mode="local"; shift ;;
    --remote) mode="remote"; shift ;;
    --) shift; positional+=("$@"); break ;;
    -*)
      echo "review-start: unknown flag '$1'" >&2
      echo "Usage: review-start [--local] <slug> [<base-ref>]" >&2
      exit 64
      ;;
    *) positional+=("$1"); shift ;;
  esac
done

if [[ ${#positional[@]} -lt 1 ]]; then
  echo "Usage: review-start [--local] <slug> [<base-ref>]" >&2
  exit 64
fi

raw_slug="${positional[0]}"
base_ref="${positional[1]:-}"

slug="$(_rv_sanitize_slug "$raw_slug")"
if [[ -z "$slug" ]]; then
  echo "review-start: slug must contain at least one alphanumeric character" >&2
  exit 64
fi

if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "review-start: $PWD is not inside a git repo" >&2
  exit 1
fi

real_git_dir=$(git rev-parse --absolute-git-dir)
project_dir="$(_rv_project_dir)"
store="$(_rv_store_dir "$slug")"

if [[ -d "$store/repo" ]]; then
  echo "review-start: store already exists at $store" >&2
  echo "  use 'review-end $slug' to remove it first" >&2
  exit 1
fi

if [[ "$mode" == "local" ]]; then
  base_sha=$(_rv_default_local_base "$base_ref")
else
  base_sha=$(_rv_default_base "$base_ref")
fi
head_sha=$(git rev-parse HEAD)
head_ref=$(git symbolic-ref --short HEAD 2>/dev/null || echo "(detached)")

mkdir -p "$store/repo"
git --git-dir="$store/repo" init --quiet
git --git-dir="$store/repo" config core.bare false
git --git-dir="$store/repo" config user.name  "${REVIEW_USER_NAME:-PR Reviewer}"
git --git-dir="$store/repo" config user.email "${REVIEW_USER_EMAIL:-reviewer@local}"

# Alternates: reference the real repo's object store. No copying.
mkdir -p "$store/repo/objects/info"
echo "$real_git_dir/objects" > "$store/repo/objects/info/alternates"

# Set HEAD to a commit whose tree is the baseline — without disturbing the working tree.
tree_sha=$(git rev-parse "$base_sha^{tree}")
commit_sha=$(GIT_AUTHOR_NAME="PR Reviewer" GIT_AUTHOR_EMAIL="reviewer@local" \
             GIT_COMMITTER_NAME="PR Reviewer" GIT_COMMITTER_EMAIL="reviewer@local" \
             git --git-dir="$store/repo" commit-tree "$tree_sha" -m "base: ${base_sha:0:8}")
git --git-dir="$store/repo" update-ref HEAD "$commit_sha"

# Common state.
_rv_state_write "$store" "MODE" "$mode"
_rv_state_write "$store" "PR_REF" "$head_ref"
_rv_state_write "$store" "BASE_SHA" "$base_sha"
_rv_state_write "$store" "REVIEW_BASE_COMMIT" "$commit_sha"
_rv_state_write "$store" "STARTED_AT" "$(_rv_now)"
_rv_state_write "$store" "LAST_REFRESHED_AT" "$(_rv_now)"
_rv_state_write "$store" "PROJECT_DIR" "$project_dir"

if [[ "$mode" == "local" ]]; then
  # Capture the working tree (incl. untracked, excl. gitignored) as a tree.
  snapshot_tree=$(_rv_capture_snapshot "$project_dir")
  if [[ -z "$snapshot_tree" ]]; then
    echo "review-start: failed to capture snapshot tree" >&2
    rm -rf "$store"
    exit 1
  fi
  _rv_state_write "$store" "SNAPSHOT_TREE" "$snapshot_tree"

  # Materialize the snapshot tree into $store/snapshot. This populates the
  # work-tree (the read-only review surface) but does not touch the index.
  _rv_materialize_snapshot "$store" "$snapshot_tree"

  # Now set up the index = HEAD's tree (baseline) + intent-to-add for files
  # that are in the snapshot but not in baseline.
  git --git-dir="$store/repo" --work-tree="$store/snapshot" read-tree HEAD
  _rv_intent_to_add_untracked "$store"

  cat <<EOF
Review store created (local mode).

  Slug:     $slug
  Project:  $project_dir
  Baseline: ${base_sha:0:8}  (${base_ref:-HEAD})
  Snapshot: ${snapshot_tree:0:8}
  Store:    $store
  View:     $store/snapshot   (frozen — AI edits to $project_dir won't appear
                              until you run \`review-refresh $slug\`)

Activate with:
  review-shell $slug
EOF
else
  # Remote mode: work tree is the live project directory.
  git --git-dir="$store/repo" --work-tree="$project_dir" read-tree HEAD

  # Mark untracked files as intent-to-add so they appear in `git diff`
  # (otherwise new files in the PR are invisible to diff). Honors .gitignore.
  while IFS= read -r -d '' f; do
    git --git-dir="$store/repo" --work-tree="$project_dir" add --intent-to-add -- "$f"
  done < <(git --git-dir="$store/repo" --work-tree="$project_dir" \
             ls-files --others --exclude-standard -z)

  cat <<EOF
Review store created.

  Slug:    $slug
  Project: $project_dir
  Base:    ${base_sha:0:8}  (${base_ref:-merge-base})
  HEAD:    ${head_sha:0:8}  ($head_ref)
  Store:   $store

Activate with:
  review-shell $slug

Or set in your current shell:
  export GIT_DIR=$store/repo
  export GIT_WORK_TREE=$project_dir
EOF
fi
