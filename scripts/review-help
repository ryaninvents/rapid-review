#!/usr/bin/env bash
# Quick reference for the rapid-review workflow.
#
# Usage:
#   review-help            print the cheatsheet (this)
#   review-help --full     open docs/review-workflow.md in $PAGER

set -euo pipefail

# Resolve our own path (through symlinks) to find ../docs/review-workflow.md.
_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do _self="$(readlink "$_self")"; done
_dir="$(cd "$(dirname "$_self")" && pwd)"
_docs="$_dir/../docs/review-workflow.md"

if [[ "${1:-}" == "--full" ]]; then
  if [[ -f "$_docs" ]]; then
    exec "${PAGER:-less}" "$_docs"
  else
    echo "review-help: full doc not found at $_docs" >&2
    echo "  (only the cheatsheet is available in this install)" >&2
    exit 1
  fi
fi

cat <<EOF
rapid-review — quick reference

Shell commands:
  review-start <slug> [<base>]            init a review store (remote/PR mode)
  review-start --local <slug> [<base>]    init for reviewing a frozen snapshot
                                          of the working tree (e.g. AI changes)
  review-shell [<slug>]                   subshell with GIT_DIR set
  nvim-review [files…]                    launch nvim with sidebar open
  review-status [<slug>]                  progress summary (shows mode)
  review-list                             list stores; tagged remote/local
  review-refresh [<slug>]                 remote: git fetch + pull
                                          local:  re-snapshot working tree
                                          (run OUTSIDE review-shell)
  review-remaining [<slug>]               diff of remaining unreviewed code
  review-end <slug> [--force]             delete a review store
  review-help [--full]                    this cheatsheet; --full opens the doc

Inside the nvim sidebar:
  j / k          navigate
  l / <CR>       open file in adjacent window (double-click also works)
  o              open colored diff
  s              toggle staged (V-select multiple rows for group toggle)
  c              commit reviewed batch
  r              refresh
  q              close

Global <leader>r* keymaps (nvim):
  rr             toggle sidebar
  rd             open diff view              (sidebar-aware)
  rf             toggle staged file          (sidebar-aware)
  rh / rl        stage hunk / line range     (gitsigns; file buffer)
  rc             commit batch
  rs             status (floating window)
  ru             refresh sidebar
  rZ             undo last batch             (prompts)
  rn             jump to next unreviewed file

Full docs: $(test -f "$_docs" && echo "$_docs" || echo "(not bundled in this install)")
Or run:    review-help --full
EOF
